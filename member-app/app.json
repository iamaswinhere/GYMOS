{
  "expo": {
    "name": "GYMOS Members",
    "slug": "member-app",
    "scheme": "gymos-member",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.iamaswinhere.gymos",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.iamaswinhere.gymos",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": {
            "scheme": "upi"
          },
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "pwa": {
        "name": "GYMOS Members",
        "shortName": "GYMOS",
        "description": "Premium Gym Management & Member Experience",
        "themeColor": "#000000",
        "backgroundColor": "#000000",
        "display": "standalone",
        "orientation": "portrait"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow GYMOS to access your camera to scan check-in QR codes."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "67227f19-3ecc-40d6-bac3-e269f572dbba"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/67227f19-3ecc-40d6-bac3-e269f572dbba"
    }
  }
}
